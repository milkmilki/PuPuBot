ANTHROPIC_BASE_URL=https://xinghuapi.com
ANTHROPIC_API_KEY=sk-jacLOQDhdRufr1RokATNunxp7u93J6UwvdP686rkJcLoLwCU

# Main Anthropic model names.
PUPU_MODEL=claude-opus-4-6
PUPU_JUDGE_MODEL=claude-haiku-4-5-20251001

# Provider routing. Supported today: anthropic, codex_cli, xiaoshuoai, deepseek.
# Defaults are anthropic when unset.
PUPU_CHAT_PROVIDER=deepseek
PUPU_JUDGE_PROVIDER=deepseek
PUPU_MAINTENANCE_PROVIDER=deepseek
PUPU_PROACTIVE_PROVIDER=deepseek

# memU long-term memory index. PuPu stores long-term memories locally in SQLite,
# and uses Bailian/DashScope only for embedding/search.
PUPU_MEMU_ENABLED=auto
PUPU_MEMU_DB_PATH=data/memu.db
PUPU_MEMU_RETRIEVE_TOP_K=6
PUPU_MEMU_METHOD=rag
PUPU_MEMU_LOG_PREVIEW_CHARS=220
PUPU_MEMU_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
PUPU_MEMU_API_KEY=sk-20fff739837f439c9424cc0e9a1d9192
PUPU_MEMU_EMBED_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
PUPU_MEMU_EMBED_API_KEY=sk-20fff739837f439c9424cc0e9a1d9192
PUPU_MEMU_EMBED_MODEL=text-embedding-v4
PUPU_MEMU_LLM_BASE_URL=https://api.deepseek.com
PUPU_MEMU_LLM_API_KEY=sk-38f7f3b06f5148a59fd9247b7ab0e49d
PUPU_MEMU_LLM_MODEL=deepseek-v4-flash
PUPU_MEMU_NATIVE_CATEGORY_SUMMARIES=false

# Optional GPT4Novel / xiaoshuoai OpenAI-compatible provider.
# Switch at runtime with: /provider xiaoshuoai
PUPU_XIAOSHUOAI_BASE_URL=https://www.gpt4novel.com/api/xiaoshuoai/ext/v1/chat/completions
PUPU_XIAOSHUOAI_API_KEY=d900df62-f986-44e0-93f2-5cff344ce74e
PUPU_XIAOSHUOAI_MODEL=nalang-max-0826
PUPU_XIAOSHUOAI_TIMEOUT=90
PUPU_XIAOSHUOAI_TEMPERATURE=0.7

# Optional DeepSeek OpenAI-compatible provider.
# Switch at runtime with: /provider deepseek
PUPU_DEEPSEEK_BASE_URL=https://api.deepseek.com/anthropic
PUPU_DEEPSEEK_API_KEY=sk-38f7f3b06f5148a59fd9247b7ab0e49d
PUPU_DEEPSEEK_MODEL=deepseek-v4-pro[1m]
# DeepSeek thinking effort for Anthropic format: high / max.
# Compatibility mapping: low/medium -> high, xhigh -> max.
PUPU_DEEPSEEK_EFFORT=max
PUPU_DEEPSEEK_TIMEOUT=90
PUPU_DEEPSEEK_TEMPERATURE=0.7

# Optional Codex CLI settings. Codex uses the local logged-in ChatGPT account.
# Optional absolute path when PuPu's startup environment cannot find codex on PATH.
PUPU_CODEX_BIN=
# Optional proxy used only by PuPu-launched Codex CLI subprocesses.
# Keep Clash running, but system proxy can be off.
PUPU_CODEX_PROXY=http://127.0.0.1:7890
PUPU_CODEX_NO_PROXY=localhost,127.0.0.1,::1
# Optional Codex config profile from ~/.codex/config.toml.
PUPU_CODEX_PROFILE=
# Leave PUPU_CODEX_MODEL empty to use your Codex CLI default model.
PUPU_CODEX_MODEL=gpt-5.5
# Override Codex reasoning effort for PuPu: low / medium / high / xhigh.
PUPU_CODEX_REASONING_EFFORT=low
PUPU_CODEX_CHAT_TIMEOUT=180
PUPU_CODEX_JSON_TIMEOUT=240
PUPU_CODEX_SANDBOX=read-only
# bridge is the reliable PuPu-managed tool loop; mcp uses Codex CLI's MCP client directly.
PUPU_CODEX_TOOL_MODE=bridge
PUPU_CODEX_TOOL_ROUNDS=4

# Optional GPT-SoVITS voice replies for OneBot/NapCat.
# PuPu sends text first; voice generation failures fall back to text-only.
PUPU_TTS_ENABLED=true
PUPU_TTS_REPLY_DEFAULT=false
PUPU_TTS_BASE_URL=http://127.0.0.1:9880
PUPU_TTS_REF_AUDIO=D:\ProjectICreate\PuPuBot\GPT-SoVITS\pupu_reference\pupu_ref.wav
PUPU_TTS_PROMPT_TEXT=
PUPU_TTS_PROMPT_TEXT_FILE=D:\ProjectICreate\PuPuBot\GPT-SoVITS\pupu_reference\pupu_ref.txt
PUPU_TTS_PROMPT_LANG=zh
PUPU_TTS_TEXT_LANG=zh
PUPU_TTS_MAX_CHARS=120
PUPU_TTS_TIMEOUT=60
PUPU_TTS_MEDIA_TYPE=wav
PUPU_TTS_TEXT_SPLIT_METHOD=cut5
PUPU_TTS_NORMALIZE_AUDIO=true
PUPU_TTS_FFMPEG=D:\ProjectICreate\PuPuBot\Miniforge3\envs\GPTSoVits\Library\bin\ffmpeg.exe
PUPU_TTS_TOP_K=15
PUPU_TTS_TOP_P=1.0
PUPU_TTS_TEMPERATURE=1.0
PUPU_TTS_REPETITION_PENALTY=1.35
PUPU_TTS_SPEED_FACTOR=1.0
PUPU_TTS_SEED=-1
PUPU_TTS_PARALLEL_INFER=true
PUPU_TTS_SAMPLE_STEPS=32
PUPU_TTS_SUPER_SAMPLING=false
